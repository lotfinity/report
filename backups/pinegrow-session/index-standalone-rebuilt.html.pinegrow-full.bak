  html {
height: auto;
}

html.lenis, html.lenis body {
  height: auto;
}

.lenis.lenis-smooth {
  scroll-behavior: auto !important;
}

.lenis.lenis-smooth [data-lenis-prevent] {
  overscroll-behavior: contain;
}

.lenis.lenis-stopped {
  overflow: hidden;
}

.lenis.lenis-smooth iframe {
  pointer-events: none;
}
</style><style>
[text-split] {opacity: 0;}
html.w-editor [text-split] {opacity: 1;}
.line {
  overflow: hidden;
  position: relative;
  padding-bottom: 0.1em;
  margin-bottom: -0.1em;
}
.line span {
  display: inline-block;
  /* Убираем transform отсюда - GSAP будет управлять им */
}

.char {
  display: inline-block;
  white-space: nowrap;
}

.word {
  display: inline-block;
  white-space: normal;
}

.text-split-wrap {
  word-break: keep-all;
  overflow-wrap: normal;
}
</style>
<style>
.preloader {
	display: flex;
}
html.w-editor .preloader {
	display: none;
}
</style><style id="extra-grid-scroll-tuning">
@media screen and (min-width: 768px) {
  .design-container._1 { height: 760vh; }
  .design-container._2 { height: 900vh; }
}
@media screen and (max-width: 767px) {
  .design-container._1 { height: 1000vh; }
  .design-container._2 { height: 1600vh; }
}
</style><style id="row2-evidence-cards">
.evidence-card-link{color:inherit;text-decoration:none;display:flex;flex-flow:column;height:100%;min-height:0;gap:.85em}
.evidence-shot-wrap{background:#111;border-radius:4px;overflow:hidden;width:100%;height:12.2em;flex:none;position:relative}
.evidence-shot{width:100%;height:100%;object-fit:cover;object-position:top center;display:block;filter:saturate(.95) contrast(1.03)}
.evidence-copy{display:flex;flex-flow:column;gap:.55em;min-height:0}
.evidence-kicker{color:var(--yellow);font-size:.72em;line-height:1;text-transform:uppercase;letter-spacing:0;font-weight:600}
.evidence-title{margin:0;line-height:1.05}
.evidence-body{max-width:31em}
.evidence-metrics{display:grid;grid-template-columns:1fr 1fr;gap:.4em;margin-top:.2em}
.evidence-metric{border:1px solid rgba(255,255,255,.12);border-radius:4px;padding:.48em .55em;background:rgba(255,255,255,.035)}
.evidence-metric span{display:block;color:rgba(255,255,255,.52);font-size:.68em;line-height:1.1;text-transform:uppercase}
.evidence-metric strong{display:block;color:#fff;font-size:.92em;line-height:1.15;margin-top:.15em}
.evidence-open{color:var(--yellow);font-size:.78em;text-transform:uppercase;margin-top:auto;line-height:1.1}
.slide-1-grid .extra-grid-slot .evidence-shot-wrap{height:11.4em}
@media screen and (max-width:767px){.evidence-shot-wrap{height:10.5em}.evidence-metrics{grid-template-columns:1fr}.evidence-body{font-size:.9em}}
</style><style id="video-placeholder-cards">
.video-placeholder-link{display:block;width:100%;height:100%;min-height:12em;overflow:hidden;border-radius:4px;background:#111}
.video-placeholder-link.video{display:block}
.video-placeholder-image{display:block;width:100%;height:100%;object-fit:cover;object-position:center}
._3d-yellow .video-placeholder-link{min-height:100%;height:100%}
</style><style id="camera-control-placeholder-style">
.camera-control-img-grid .img-hover{overflow:hidden}
.camera-control-placeholder{display:block;width:100%;height:100%;object-fit:cover;object-position:center}
</style><style id="camera-control-single-image-style">
.camera-control-img-grid.single-camera-image{display:block;width:100%;height:100%}
.camera-control-img-grid.single-camera-image .img-hover{width:100%;height:100%}
.camera-control-img-grid.single-camera-image .camera-control-placeholder{width:100%;height:100%;object-fit:cover;object-position:center}
</style></head><body><div class="w-embed"><style>

