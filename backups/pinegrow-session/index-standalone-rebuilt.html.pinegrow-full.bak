533_webflow.schunk.8208d3e53b97e3c7.js" type="text/javascript"></script><script src="assets-rebuilt/beeaf25ddb_webflow.schunk.452e1cd124749014.js" type="text/javascript"></script><script src="assets-rebuilt/321334c123_webflow.schunk.9dfb96661114d3db.js" type="text/javascript"></script><script src="assets-rebuilt/255e91b64b_webflow.0a0dc6fb.b2d15efe5b3bd215.js" type="text/javascript"></script><script src="assets-rebuilt/ebd932c57f_gsap.min.js" type="text/javascript"></script><script src="assets-rebuilt/0fc5dfc516_ScrollTrigger.min.js" type="text/javascript"></script><script src="assets-rebuilt/78c889caf2_SplitText.min.js" type="text/javascript"></script><script src="assets-rebuilt/a971210e78_CustomEase.min.js" type="text/javascript"></script><script type="text/javascript">gsap.registerPlugin(ScrollTrigger,SplitText,CustomEase);</script><script src="assets-rebuilt/7033fe897d_lenis.min.js"></script>
<script>

const lenis = new Lenis({
  })

lenis.on('scroll', (e) => {
})

