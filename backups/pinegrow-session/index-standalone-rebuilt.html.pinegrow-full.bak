<script src="assets-rebuilt/7d9f56a3ed_gsap.min.js"></script>
<script src="assets-rebuilt/0e37abfac9_ScrollTrigger.min.js"></script>
<script>
  window.addEventListener("DOMContentLoaded", () => {
    // Делаем сплит по буквам
    let typeSplit = new SplitType("[text-split], [text-split-delay]", {
      types: "lines words chars",
      tagName: "span",
      preserveWhitespace: true
    });
    document.querySelectorAll("[text-split], [text-split-delay]").forEach(el => {
     el.classList.add("text-split-wrap");
     });
    function createScrollTrigger(triggerElement, timeline) {
      ScrollTrigger.create({
        trigger: triggerElement,
        start: "top bottom",
        onLeaveBack: () => {
          timeline.progress(0);
          timeline.pause();
        }
      });
      ScrollTrigger.create({
        trigger: triggerElement,
        start: "top 60%",
        onEnter: () => timeline.play()
      });
    }

    // Анимация без задержки
    $("[text-split]").each(function () {
      let tl = gsap.timeline({ paused: true });

      const chars = $(this).find(".char");

      gsap.set(chars, {
        opacity: 0
      });

      tl.to(chars, {
        opacity: 1,
        duration: 0.4,
        ease: "power2.out",
        stagger: {
          each: 0.02,
          from: "random"
        }
      });

      createScrollTrigger($(this), tl);
    });

    // Анимация с задержкой по атрибуту
    $("[text-split-delay]").each(function () {
      let tl = gsap.timeline({ paused: true });

      const delayValue = parseFloat($(this).attr('text-split-delay')) || 0;
      const chars = $(this).find(".char");

      gsap.set(chars, {
        opacity: 0
      });

      tl.to(chars, {
        opacity: 1,
        duration: 0.4,
        ease: "power2.out",
        stagger: {
          each: 0.02,
          from: "random"
        },
        delay: delayValue
      });

      createScrollTrigger($(this), tl);
    });

    // Показываем обёртки после разбиения
    gsap.set("[text-split], [text-split-delay]", { opacity: 1 });
  });
</script>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    if (window.innerWidth >= 0) {
      // Сохраняем текущую позицию скролла
      const scrollY = window.scrollY || window.pageYOffset;

      // Блокируем прокрутку
      document.body.style.position = 'fixed';
      document.body.style.top = `-${scrollY}px`;
      document.body.style.left = '0';
      document.body.style.right = '0';
      document.body.style.width = '100%';

      // Через 3 секунды — возвращаем скролл
      setTimeout(() => {
        document.body.style.position = '';
        document.body.style.top = '';
        document.body.style.left = '';
        document.body.style.right = '';
        document.body.style.width = '';
        window.scrollTo(0, scrollY); // Возвращаем к исходной позиции
      }, 7800);
    }
  });

  // На случай мгновенной перезагрузки — всегда стартуем с нуля
  if (window.innerWidth >= 0) {
    window.scrollTo(0, 0);
  }
</script>
<script>
 document.addEventListener("DOMContentLoaded", () => {
    const logo = document.querySelector(".logo");
    const navMenu = document.querySelector(".nav-menu");

    const darkSections = ["hero", "demo", "benefit"];
    const lightSections = ["intro", "services", "design", "footer"];

    let currentSectionType = null;

    // Intersection Observer
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;

        const sectionId = entry.target.id;
        if (darkSections.includes(sectionId)) {
          currentSectionType = "dark";
        } else if (lightSections.includes(sectionId)) {
          currentSectionType = "light";
        }

        updateLogoColor();
      });
    }, {
      root: null,
      threshold: 0,
      rootMargin: "0px 0px -99% 0px" // сработает только когда .logo прямо входит в секцию
    });

    // Подключаем секции к observer
    [...darkSections, ...lightSections].forEach(id => {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    });

    // Проверка display состояния navMenu
    function updateLogoColor() {
      const isNavOpen = getComputedStyle(navMenu).display === "flex";

      if (isNavOpen) {
        logo.style.color = "#ffffff";
      } else {
        logo.style.color = currentSectionType === "dark" ? "#282828" : "#ffffff";
      }
    }

    // Следим за изменениями display у .nav-menu
    const menuObserver = new MutationObserver(updateLogoColor);
    menuObserver.observe(navMenu, {
      attributes: true,
      attributeFilter: ["style", "class"]
    });

    updateLogoColor(); // начальная проверка


    // tabs links
    const tabLinks = document.querySelectorAll(".tabs-menu .w-tab-link");
    const navLinks = document.querySelectorAll('[data-tab-link]');

    navLinks.forEach(link => {
      link.addEventListener("click", function () {
        const tabTarget = this.getAttribute("data-tab-link");

        if (tabTarget) {
          const matchingTab = Array.from(tabLinks).find(tab =>
                                                        tab.getAttribute("href") === tabTarget
                                                       );
          if (matchingTab) matchingTab.click();
        }
      });
    });

    // book demo
    const bookHeroBtns = document.querySelectorAll('[data-btn="book-open"]');
    const modalBook = document.querySelector('.contact-form');
    const modalBookClose = modalBook?.querySelector('.close-btn');
    let modalOpen = false;

    if (bookHeroBtns.length && modalBook && modalBookClose) {
      bookHeroBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          if (!modalOpen) {
            bookHeroBtns.forEach(b => b.classList.add('is--hide'));
            modalOpen = true;
          }
        });
      });

      modalBookClose.addEventListener('click', () => {
        if (modalOpen) {
          bookHeroBtns.forEach(b => b.classList.remove('is--hide'));
          modalOpen = false;
        }
      });
    }
  });
</script>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const menuBg = document.querySelector(".menu-bg");
    const menuDotsBtn = document.querySelector(".menu-dots-btn");
    const navMenu = document.querySelector(".nav-menu");
    
    const sectionColors = {
      hero: "#E7E5DD",
      demo: "#FDFDFD",
      benefit: "#FDFDFD",
      intro: "#282828",
      services: "#0C0A0B",
      design: "#0C0A0B",
      footer: "#282828"
    };

    let isMenuOpen = false;

    // Функция для проверки открытости меню
    const checkMenuState = () => {
      if (navMenu) {
        const computedStyle = window.getComputedStyle(navMenu);
        isMenuOpen = computedStyle.display === 'flex';
        
        // Если меню открыто, делаем фон прозрачным
        if (isMenuOpen && menuBg) {
          menuBg.style.backgroundColor = 'transparent';
        }
      }
    };

    // Наблюдатель за кликом по кнопке меню
    if (menuDotsBtn) {
      menuDotsBtn.addEventListener('click', () => {
        // Небольшая задержка, чтобы дать время измениться display
        setTimeout(checkMenuState, 10);
      });
    }

    // Наблюдатель за изменениями в DOM (на случай если меню закрывается другим способом)
    if (navMenu) {
      const menuObserver = new MutationObserver(() => {
        setTimeout(checkMenuState, 10);
      });
      
      menuObserver.observe(navMenu, {
        attributes: true,
        attributeFilter: ['style', 'class']
      });
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        
        // Проверяем состояние меню перед изменением фона
        checkMenuState();
        
        // Если меню открыто, не меняем фон
        if (isMenuOpen) return;
        
        const id = entry.target.id;
        const bgColor = sectionColors[id];
        if (bgColor && menuBg) {
          menuBg.style.backgroundColor = bgColor;
        }
      });
    }, {
      threshold: 0,
      rootMargin: "0px 0px -99% 0px"
    });

    Object.keys(sectionColors).forEach(id => {
      const section = document.getElementById(id);
      if (section) observer.observe(section);
    });
  });
</script>
<script>
  // variables
  let customEase =
    "M0,0,C0,0,0.13,0.34,0.238,0.442,0.305,0.506,0.322,0.514,0.396,0.54,0.478,0.568,0.468,0.56,0.522,0.584,0.572,0.606,0.61,0.719,0.714,0.826,0.798,0.912,1,1,1,1";

  let counter = { value: 0 };
  let loaderDuration = 4; // <-- всегда 4 секунды

  function updateLoaderText() {
    let progress = Math.round(counter.value);
    $(".preloader_numbers").text(progress);
  }

  function endLoaderAnimation() {
    $(".trigger").click();
  }

  let tl = gsap.timeline({
    onComplete: endLoaderAnimation
  });

  tl.to(counter, {
    value: 100,
    onUpdate: updateLoaderText,
    duration: loaderDuration,
    ease: CustomEase.create("custom", customEase)
  });

  tl.to(".preloader_progress-bar", {
    width: "100%",
    duration: loaderDuration,
    ease: CustomEase.create("custom", customEase)
  }, 0);
 



document.addEventListener('DOMContentLoaded', function() {
  // Обработка для каждой группы табов (старый код)
  for (let i = 1; i <= 3; i++) {
    const buttons = document.querySelectorAll(`.estimate-card-items.tab0${i} .estimate-card-item`);
    const desktopTabs = document.querySelectorAll(`.est-shop-bg-desk-${i} .est-shop-dg-item`);
    const mobileTabs = document.querySelectorAll(`.est-shop-bg-mob-${i} .est-shop-dg-item`);
    
    buttons.forEach((button, index) => {
      button.addEventListener('click', () => {
        // Убираем активный класс у всех табов всех групп
        for (let j = 1; j <= 3; j++) {
          document.querySelectorAll(`.est-shop-bg-desk-${j} .est-shop-dg-item`).forEach(tab => tab.classList.remove('active-tab'));
          document.querySelectorAll(`.est-shop-bg-mob-${j} .est-shop-dg-item`).forEach(tab => tab.classList.remove('active-tab'));
        }
        
        // Убираем активность только у фонов комнат
        document.querySelectorAll('.est-shop-bg-rooms .est-shop-dg-item').forEach(bg => bg.classList.remove('active-tab'));
        
        // Добавляем активный класс только в текущей группе
        if (desktopTabs[index]) {
          desktopTabs[index].classList.add('active-tab');
        }
        if (mobileTabs[index]) {
          mobileTabs[index].classList.add('active-tab');
        }
      });
    });
  }
  
  // Новый код для комнат
  const roomButtons = document.querySelectorAll('.shop-card-button-wrapper .shop-card-button');
  const roomTabs = document.querySelectorAll('.estimate-card-items-wrap.rooms .estimate-card-items.rooms');
  const roomBgs = document.querySelectorAll('.est-shop-bg-rooms .est-shop-dg-item');
  const roomBgsMob = document.querySelectorAll('.est-shop-bg-rooms-mob .est-shop-dg-item');
  
  roomButtons.forEach((button, index) => {
    button.addEventListener('click', () => {
      // Убираем активность у всех старых групп
      for (let j = 1; j <= 3; j++) {
        document.querySelectorAll(`.est-shop-bg-desk-${j} .est-shop-dg-item`).forEach(tab => tab.classList.remove('active-tab'));
        document.querySelectorAll(`.est-shop-bg-mob-${j} .est-shop-dg-item`).forEach(tab => tab.classList.remove('active-tab'));
      }
      
      // Убираем активность у всех кнопок комнат и добавляем текущей
      roomButtons.forEach(btn => btn.classList.remove('is-activ'));
      button.classList.add('is-activ');
      
      // Убираем активность у всех табов комнат и добавляем нужному
      roomTabs.forEach(tab => tab.classList.remove('is-activ'));
      if (roomTabs[index]) {
        roomTabs[index].classList.add('is-activ');
      }
      
      // Убираем активность у всех фонов комнат и добавляем нужному
      roomBgs.forEach(bg => bg.classList.remove('active-tab'));
      if (roomBgs[index]) {
        roomBgs[index].classList.add('active-tab');
      }
      
      // Работаем с мобильными фонами комнат
      roomBgsMob.forEach(bg => bg.classList.remove('active-tab'));
      if (roomBgsMob[index]) {
        roomBgsMob[index].classList.add('active-tab');
      }
    });
  });
});

</script></body></html>